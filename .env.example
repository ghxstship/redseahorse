# GHXSTSHIP — contact form (Resend). Copy to Vercel → Project → Settings →
# Environment Variables. Do NOT commit real values.

# Required: your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: verified sender. Defaults to Resend's shared onboarding@resend.dev,
# which can only deliver to your own Resend account email. Once you verify
# ghxstship.tours in Resend, set e.g. "GHXSTSHIP <hello@ghxstship.tours>".
# RESEND_FROM="GHXSTSHIP <onboarding@resend.dev>"

# Optional: where inquiries are delivered. Defaults to julian.clarkson@ghxstship.pro
# CONTACT_TO=julian.clarkson@ghxstship.pro
